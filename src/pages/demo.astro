---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Demo | imurar">
  <section>
    <h1 class="text-3xl font-bold mb-2">Demo</h1>
    <p class="text-gray-600 mb-12">HTML / CSS / JavaScript で実装したコンポーネントのサンプルです。</p>

    <!-- ========== UI コンポーネント ========== -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold mb-8 pb-2 border-b-2 border-gray-200">UI コンポーネント</h2>

      <!-- ボタン -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold mb-4 text-gray-700">ボタン</h3>
        <div class="flex flex-wrap gap-3">
          <button class="px-5 py-2 bg-gray-900 text-white rounded-lg font-medium hover:bg-gray-700 transition">Primary</button>
          <button class="px-5 py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-500 transition">Secondary</button>
          <button class="px-5 py-2 border-2 border-gray-900 text-gray-900 rounded-lg font-medium hover:bg-gray-900 hover:text-white transition">Outline</button>
          <button class="px-5 py-2 bg-red-500 text-white rounded-lg font-medium hover:bg-red-400 transition">Danger</button>
          <button class="px-5 py-2 bg-gray-200 text-gray-400 rounded-lg font-medium cursor-not-allowed" disabled>Disabled</button>
        </div>
      </div>

      <!-- バッジ -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold mb-4 text-gray-700">バッジ</h3>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-blue-100 text-blue-800 text-sm font-medium rounded-full">New</span>
          <span class="px-3 py-1 bg-green-100 text-green-800 text-sm font-medium rounded-full">Success</span>
          <span class="px-3 py-1 bg-yellow-100 text-yellow-800 text-sm font-medium rounded-full">Warning</span>
          <span class="px-3 py-1 bg-red-100 text-red-800 text-sm font-medium rounded-full">Error</span>
          <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm font-medium rounded-full">Default</span>
        </div>
      </div>

      <!-- カード -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold mb-4 text-gray-700">カード</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="border border-gray-200 rounded-xl p-5 hover:shadow-md transition">
            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mb-3 text-blue-600 font-bold">A</div>
            <h4 class="font-semibold mb-1">カードタイトル</h4>
            <p class="text-sm text-gray-600">サンプルのカードコンポーネントです。ホバーで影が付きます。</p>
          </div>
          <div class="border border-gray-200 rounded-xl p-5 hover:shadow-md transition">
            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center mb-3 text-green-600 font-bold">B</div>
            <h4 class="font-semibold mb-1">カードタイトル</h4>
            <p class="text-sm text-gray-600">サンプルのカードコンポーネントです。ホバーで影が付きます。</p>
          </div>
          <div class="border border-gray-200 rounded-xl p-5 hover:shadow-md transition">
            <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center mb-3 text-purple-600 font-bold">C</div>
            <h4 class="font-semibold mb-1">カードタイトル</h4>
            <p class="text-sm text-gray-600">サンプルのカードコンポーネントです。ホバーで影が付きます。</p>
          </div>
        </div>
      </div>

      <!-- アラート -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold mb-4 text-gray-700">アラート</h3>
        <div class="space-y-3">
          <div class="flex gap-3 p-4 bg-blue-50 border border-blue-200 rounded-lg text-blue-800 text-sm">
            <span class="font-bold shrink-0">ℹ️</span>
            <p>情報メッセージのサンプルです。</p>
          </div>
          <div class="flex gap-3 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800 text-sm">
            <span class="font-bold shrink-0">✅</span>
            <p>成功メッセージのサンプルです。</p>
          </div>
          <div class="flex gap-3 p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-yellow-800 text-sm">
            <span class="font-bold shrink-0">⚠️</span>
            <p>警告メッセージのサンプルです。</p>
          </div>
          <div class="flex gap-3 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800 text-sm">
            <span class="font-bold shrink-0">❌</span>
            <p>エラーメッセージのサンプルです。</p>
          </div>
        </div>
      </div>

      <!-- フォームパーツ -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold mb-4 text-gray-700">フォームパーツ</h3>
        <div class="max-w-md space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">テキスト入力</label>
            <input type="text" placeholder="入力してください" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-gray-800" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">セレクトボックス</label>
            <select class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-gray-800 bg-white">
              <option>選択してください</option>
              <option>オプション 1</option>
              <option>オプション 2</option>
            </select>
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" id="check1" class="w-4 h-4 accent-gray-900" />
            <label for="check1" class="text-sm text-gray-700">チェックボックス</label>
          </div>
          <div class="flex gap-4">
            <label class="flex items-center gap-2 text-sm text-gray-700">
              <input type="radio" name="radio" class="accent-gray-900" /> ラジオ A
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-700">
              <input type="radio" name="radio" class="accent-gray-900" /> ラジオ B
            </label>
          </div>
        </div>
      </div>
    </div>
    <!-- ========== ミニアプリ ========== -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold mb-8 pb-2 border-b-2 border-gray-200">ミニアプリ</h2>

      <!-- 文字数カウンター -->
      <div class="mb-12">
        <h3 class="text-lg font-semibold mb-4 text-gray-700">文字数カウンター</h3>
        <div class="max-w-lg border border-gray-200 rounded-xl p-6">
          <textarea
            id="char-input"
            rows="6"
            placeholder="テキストを入力してください..."
            class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-gray-800 resize-none mb-4"
          ></textarea>

          <div class="grid grid-cols-3 gap-3 mb-4">
            <div class="bg-gray-50 rounded-lg p-3 text-center">
              <div id="count-all" class="text-2xl font-bold text-gray-900">0</div>
              <div class="text-xs text-gray-500 mt-1">文字数（全体）</div>
            </div>
            <div class="bg-gray-50 rounded-lg p-3 text-center">
              <div id="count-no-space" class="text-2xl font-bold text-gray-900">0</div>
              <div class="text-xs text-gray-500 mt-1">文字数（空白除く）</div>
            </div>
            <div class="bg-gray-50 rounded-lg p-3 text-center">
              <div id="count-lines" class="text-2xl font-bold text-gray-900">0</div>
              <div class="text-xs text-gray-500 mt-1">行数</div>
            </div>
          </div>

          <div class="flex gap-3">
            <div class="flex-1">
              <label class="text-xs text-gray-500 mb-1 block">上限文字数</label>
              <input id="char-limit" type="number" value="140" min="1"
                class="w-full border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-800" />
            </div>
            <div class="flex-1">
              <label class="text-xs text-gray-500 mb-1 block">残り文字数</label>
              <div id="count-remaining" class="border border-gray-200 rounded-lg px-3 py-1.5 text-sm font-bold text-gray-900 bg-gray-50">140</div>
            </div>
          </div>

          <button id="clear-btn"
            class="mt-4 w-full py-2 border border-gray-300 text-gray-600 rounded-lg text-sm hover:bg-gray-50 transition">
            クリア
          </button>
        </div>
      </div>
    </div>

    <!-- ========== CSS アニメーション ========== -->
    <div class="mb-16">
      <h2 class="text-2xl font-bold mb-8 pb-2 border-b-2 border-gray-200">CSS アニメーション</h2>

      <!-- フェードイン -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold mb-4 text-gray-700">フェードイン</h3>
        <div class="flex flex-wrap gap-4">
          <div class="w-24 h-24 bg-blue-400 rounded-xl animate-fade"></div>
          <div class="w-24 h-24 bg-green-400 rounded-xl animate-fade" style="animation-delay: 0.2s"></div>
          <div class="w-24 h-24 bg-purple-400 rounded-xl animate-fade" style="animation-delay: 0.4s"></div>
        </div>
      </div>

      <!-- スライドイン -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold mb-4 text-gray-700">スライドイン</h3>
        <div class="space-y-3 overflow-hidden">
          <div class="h-12 bg-gray-900 text-white rounded-lg flex items-center px-4 font-medium animate-slide-left">← 左からスライド</div>
          <div class="h-12 bg-gray-700 text-white rounded-lg flex items-center px-4 font-medium animate-slide-right" style="animation-delay: 0.2s">右からスライド →</div>
        </div>
      </div>

      <!-- ホバーエフェクト -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold mb-4 text-gray-700">ホバーエフェクト</h3>
        <div class="flex flex-wrap gap-4">
          <div class="w-28 h-28 bg-blue-500 rounded-xl cursor-pointer hover:scale-110 transition-transform duration-300 flex items-center justify-center text-white text-sm font-medium">スケール</div>
          <div class="w-28 h-28 bg-green-500 rounded-xl cursor-pointer hover:rotate-12 transition-transform duration-300 flex items-center justify-center text-white text-sm font-medium">回転</div>
          <div class="w-28 h-28 bg-purple-500 rounded-xl cursor-pointer hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 flex items-center justify-center text-white text-sm font-medium">浮き上がり</div>
          <div class="w-28 h-28 bg-gray-800 rounded-xl cursor-pointer hover:bg-orange-500 transition-colors duration-500 flex items-center justify-center text-white text-sm font-medium">色変化</div>
        </div>
      </div>

      <!-- ローディング -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold mb-4 text-gray-700">ローディング</h3>
        <div class="flex flex-wrap items-center gap-8">
          <div class="w-10 h-10 border-4 border-gray-200 border-t-gray-900 rounded-full animate-spin"></div>
          <div class="flex gap-1">
            <div class="w-3 h-3 bg-gray-900 rounded-full animate-bounce" style="animation-delay: 0s"></div>
            <div class="w-3 h-3 bg-gray-900 rounded-full animate-bounce" style="animation-delay: 0.15s"></div>
            <div class="w-3 h-3 bg-gray-900 rounded-full animate-bounce" style="animation-delay: 0.3s"></div>
          </div>
          <div class="w-32 h-3 bg-gray-200 rounded-full overflow-hidden">
            <div class="h-full bg-gray-900 rounded-full animate-progress"></div>
          </div>
        </div>
      </div>

      <!-- パルス -->
      <div class="mb-10">
        <h3 class="text-lg font-semibold mb-4 text-gray-700">パルス・点滅</h3>
        <div class="flex flex-wrap items-center gap-6">
          <div class="relative">
            <div class="w-12 h-12 bg-green-500 rounded-full flex items-center justify-center text-white text-xs font-bold">ON</div>
            <div class="absolute inset-0 bg-green-400 rounded-full animate-ping opacity-75"></div>
          </div>
          <div class="px-5 py-2 bg-red-500 text-white rounded-lg font-medium animate-pulse">重要なお知らせ</div>
          <div class="w-3 h-3 bg-blue-500 rounded-full animate-ping"></div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const input = document.getElementById('char-input') as HTMLTextAreaElement;
  const limitInput = document.getElementById('char-limit') as HTMLInputElement;
  const clearBtn = document.getElementById('clear-btn');

  function update() {
    const text = input.value;
    const limit = parseInt(limitInput.value) || 0;
    const all = text.length;
    const noSpace = text.replace(/\s/g, '').length;
    const lines = text === '' ? 0 : text.split('\n').length;
    const remaining = limit - all;

    document.getElementById('count-all')!.textContent = String(all);
    document.getElementById('count-no-space')!.textContent = String(noSpace);
    document.getElementById('count-lines')!.textContent = String(lines);

    const remainEl = document.getElementById('count-remaining')!;
    remainEl.textContent = String(remaining);
    remainEl.className = `border rounded-lg px-3 py-1.5 text-sm font-bold bg-gray-50 ${
      remaining < 0 ? 'border-red-400 text-red-600' :
      remaining <= 20 ? 'border-yellow-400 text-yellow-600' :
      'border-gray-200 text-gray-900'
    }`;
  }

  input.addEventListener('input', update);
  limitInput.addEventListener('input', update);
  clearBtn?.addEventListener('click', () => { input.value = ''; update(); });
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideLeft {
    from { opacity: 0; transform: translateX(-60px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes slideRight {
    from { opacity: 0; transform: translateX(60px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes progress {
    0% { width: 0%; }
    100% { width: 100%; }
  }

  .animate-fade {
    opacity: 0;
    animation: fadeIn 0.8s ease forwards;
  }
  .animate-slide-left {
    opacity: 0;
    animation: slideLeft 0.6s ease forwards;
  }
  .animate-slide-right {
    opacity: 0;
    animation: slideRight 0.6s ease forwards;
  }
  .animate-progress {
    animation: progress 2s ease-in-out infinite;
  }
</style>
