---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Android 券売機アプリ（新規開発）',
    company: '飲食店向けシステム開発会社',
    period: '2025年10月 〜 現在',
    type: '0ベース新規開発',
    typeColor: 'bg-blue-100 text-blue-800',
    description: '飲食店舗向けセルフオーダー型 Android 券売機アプリを 0 から設計・開発。現金・キャッシュレスの両決済に対応し、各種ハードウェアとの通信プロトコルを実装。約 10 店舗に展開中。',
    achievements: [
      'Kotlin による Android アプリ設計・実装（MVVM 構成・Kotlin Coroutines）',
      '釣銭機・決済端末・プリンターとのハードウェア通信プロトコル実装',
      '現金決済の障害リカバリーフロー設計（釣銭返却・強制完了・手動返金）',
      'CMS から取得したメニューレイアウトを SQLite にキャッシュし、オフライン時も表示継続',
      'バーコードスキャンによるクーポン読み取り・日次締め処理実装',
    ],
    tech: ['Kotlin', 'Android 13', 'MVVM', 'Kotlin Coroutines', 'SQLite', 'Gradle'],
  },
  {
    title: '券売機向け CMS バックエンド（新規開発）',
    company: '飲食店向けシステム開発会社',
    period: '2025年10月 〜 現在',
    type: '0ベース新規開発',
    typeColor: 'bg-blue-100 text-blue-800',
    description: 'Android 券売機向け Web CMS と POS 連携 REST API を設計・開発。マルチテナント設計・スペック駆動開発・CI/CD 構築まで一貫して担当。',
    achievements: [
      'Node.js / Express 5 による Web CMS・POS 連携 REST API の設計・実装',
      'マルチテナント設計（Company → Branch → User 階層、全クエリに branch 条件を強制）',
      'N+1 クエリ回避・ヘルスチェック API など API 設計工夫',
      'スペック駆動開発（PRD・機能設計書・アーキテクチャ設計書・開発ガイドラインを整備）',
      'Bitbucket Pipelines による staging / production への CI/CD 自動デプロイ',
    ],
    tech: ['Node.js', 'TypeScript', 'Express 5', 'MongoDB', 'AWS EC2', 'S3', 'Docker', 'Bitbucket Pipelines'],
  },
  {
    title: 'モバイルオーダーシステム（保守・改修）',
    company: '飲食店向けシステム開発会社',
    period: '2025年10月 〜 現在',
    type: '保守・機能改修',
    typeColor: 'bg-green-100 text-green-800',
    description: '飲食店向け QR コードモバイルオーダーシステムの保守・改修。約 120 店舗展開中のシステムで、Node.js v12 → v24 への複数メジャーバージョンを跨ぐアップグレードとインフラ整備を担当。',
    achievements: [
      'Node.js v12 → v24 メジャーバージョンアップ（複数バージョンを跨ぐ互換性対応を主導）',
      'Socket.IO v4 / fast-xml-parser v4 / connect-mongo v6 / Mongoose 8 移行対応',
      'AWS SDK v2 → v3（@aws-sdk/client-s3）移行',
      'Amazon DocumentDB への MongoDB 移行（TLS/SSL 対応）',
      '本番・STG が同居していた EC2 を分離し、本番・ステージング環境をそれぞれ独立して構築',
    ],
    tech: ['Node.js', 'Socket.IO', 'MongoDB', 'AWS DocumentDB', 'Express', 'Pug', 'SCSS'],
  },
  {
    title: 'POS システム外部連動機能開発',
    company: '飲食店向けシステム開発会社',
    period: '2025年10月 〜 現在',
    type: '機能追加',
    typeColor: 'bg-purple-100 text-purple-800',
    description: 'VB.NET 製飲食店向け POS システムへの外部 API 連動機能を設計・実装。Android 券売機・モバイルオーダーとのリアルタイム連携を担当。',
    achievements: [
      'Android 券売機との連動（OAuth2 認証・売上データ取得・メニュー同期・ページング対応）',
      'モバイルオーダーとの連動（HTTP Digest 認証・テーブル管理・Socket.IO イベント配信）',
      '外部オーダーの自動バージョンアップ機能・複数 API バージョン対応',
      'TLS 1.2 強制セキュア通信・ClickOnce による自動更新配信',
    ],
    tech: ['VB.NET', '.NET Framework 4.8', 'OAuth2', 'HTTP Digest', 'TLS 1.2', 'ClickOnce'],
  },
];

const prevExperience = [
  { title: 'Windows 11 移行に伴うシステム改修', company: '大手損保会社', period: '2025年6月 〜 2025年9月', tech: ['HTML', 'CSS', 'ClassicASP', 'JavaScript', 'VBScript', 'VBA', 'SQL Server'] },
  { title: '不動産向け社内業務システム開発・保守', company: '不動産会社', period: '2024年6月 〜 2025年5月', tech: ['PHP', 'CakePHP', 'Oracle', 'PL/SQL', 'jQuery'] },
  { title: '共済システム改修・テスト', company: '共済団体', period: '2023年12月 〜 2024年5月', tech: ['HTML', 'CSS', 'NEXACRO', 'SQL Server', 'Git'] },
  { title: '社内業務効率化ツール開発・保守', company: '自動車メーカー', period: '2022年4月 〜 2023年7月', tech: ['VBA', 'Excel'] },
];
---

<BaseLayout title="プロジェクト - imurar">
  <!-- ヒーロー -->
  <section class="bg-gray-900 text-white py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h1 class="text-5xl font-mono font-bold mb-2">Projects</h1>
      <p class="text-gray-300">これまでに携わった主なプロジェクトと実績です</p>
    </div>
  </section>

  <!-- メインプロジェクト -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h2 class="text-4xl font-mono font-bold mb-12">主な実績</h2>
      <div class="space-y-6">
        {projects.map((project) => (
          <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-lg transition">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
              <div>
                <h2 class="text-2xl font-bold mb-2">{project.title}</h2>
                <p class="text-gray-600">{project.company}</p>
              </div>
              <span class={`text-xs font-semibold px-4 py-2 rounded-full whitespace-nowrap ${project.typeColor}`}>
                {project.type}
              </span>
            </div>
            <p class="text-sm text-gray-500 mb-4">{project.period}</p>
            <p class="text-gray-700 mb-6 leading-relaxed">{project.description}</p>
            <div class="mb-6">
              <h3 class="text-sm font-semibold text-gray-900 mb-3">実績・対応内容</h3>
              <ul class="space-y-2">
                {project.achievements.map((item) => (
                  <li class="text-gray-700 text-sm flex gap-3">
                    <span class="text-gray-600 shrink-0">✓</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="flex flex-wrap gap-2">
              {project.tech.map((t) => (
                <span class="bg-gray-100 text-gray-700 text-xs font-medium px-3 py-1.5 rounded-full">
                  {t}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 過去経験 -->
  <section class="bg-gray-100 py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h2 class="text-4xl font-mono font-bold mb-12">その他の経験</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {prevExperience.map((exp) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
            <h3 class="text-lg font-bold mb-2">{exp.title}</h3>
            <p class="text-sm text-gray-600 mb-4">{exp.company} ・ {exp.period}</p>
            <div class="flex flex-wrap gap-2">
              {exp.tech.map((t) => (
                <span class="bg-gray-100 text-gray-700 text-xs px-3 py-1 rounded-full">
                  {t}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
