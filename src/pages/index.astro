---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="imogx - Portfolio">
  <!-- ヒーロー -->
  <section class="relative min-h-screen flex items-center justify-center py-12 overflow-hidden" style="background: linear-gradient(135deg, #f0f9ff 0%, #fef2f2 100%); background-image: url('/bg-blob1.png'), url('/bg-blob2.png'); background-size: 700px auto, 750px auto; background-position: right -100px top -50px, right 120px bottom -130px; background-repeat: no-repeat, no-repeat; animation: bgFadeIn 1.2s ease-out;">

    <div class="max-w-7xl mx-auto px-6 w-full relative z-10" style="animation: heroSlideUp 1s ease-out;">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- 左側：テキスト -->
        <div class="pt-12">
          <h1 class="text-5xl lg:text-6xl font-bold text-gray-900 mb-8 leading-tight">
            バックエンド<br />クラウドエンジニア
          </h1>
          <p class="text-lg text-gray-700 mb-10 leading-relaxed">
            新規開発から本番運用まで。Node.js・AWS を中心に、確実な技術でプロジェクトを実装・運用します。
          </p>
          <div class="flex flex-wrap gap-3 mb-10">
            <span class="px-4 py-2 bg-blue-100 text-blue-700 text-sm font-semibold rounded-full">Node.js</span>
            <span class="px-4 py-2 bg-purple-100 text-purple-700 text-sm font-semibold rounded-full">Kotlin</span>
            <span class="px-4 py-2 bg-orange-100 text-orange-700 text-sm font-semibold rounded-full">AWS</span>
          </div>
          <a href="/contact" class="inline-block bg-gray-900 text-white font-semibold px-8 py-3 rounded-lg hover:bg-gray-800 transition">
            お問い合わせ
          </a>
        </div>

        <!-- 右側：アイコン -->
        <div class="flex justify-center relative pt-8">
          <img src="/icon.png" alt="imogx" class="w-full max-w-lg object-contain drop-shadow-xl relative z-20" style="animation: bgFadeIn 1s ease-out 0.4s both;" />
        </div>
      </div>
    </div>

    <style>
      @keyframes bgFadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      @keyframes heroSlideUp {
        from { transform: translateY(40px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
      }
      @keyframes slideUpIcon {
        from { transform: translateY(100px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
      }
    </style>
  </section>


  <!-- 実績 / Selected Works -->
  <section class="bg-gray-900 text-white py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <div class="mb-12">
        <h2 class="text-5xl font-mono font-bold mb-2">Selected <span class="text-gray-400">Works</span></h2>
        <p class="text-gray-300">これまで携わった主なプロジェクトの一部をご紹介します。</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
        <div class="work-card bg-white text-gray-900 rounded-lg overflow-hidden hover:shadow-lg transition flex flex-col cursor-pointer" data-project="android">
          <img src="/images/android.jpg" alt="Android アプリ開発" class="h-48 w-full object-cover">
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold mb-2">Android アプリ開発</h3>
            <p class="text-sm text-gray-600 mb-4 flex-1">飲食店向けセルフオーダー券売機をゼロから設計・開発。決済端末・プリンターとのハードウェア連携や、REST API との通信、ローカルデータ管理まで担当。</p>
            <div class="flex flex-wrap gap-1.5 mt-auto">
              {['Kotlin', 'Android', 'Coroutines', 'MVVM', 'SQLite', 'REST API'].map(t => (
                <span class="bg-gray-100 text-gray-700 text-xs font-medium px-2.5 py-1 rounded-full">{t}</span>
              ))}
            </div>
          </div>
        </div>
        <div class="work-card bg-white text-gray-900 rounded-lg overflow-hidden hover:shadow-lg transition flex flex-col cursor-pointer" data-project="cms">
          <img src="/images/backend.jpg" alt="セルフオーダー管理バックエンド" class="h-48 w-full object-cover">
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold mb-2">セルフオーダー管理バックエンド</h3>
            <p class="text-sm text-gray-600 mb-4 flex-1">Android 券売機向け Web CMS・POS 連携 REST API を設計・開発。マルチテナント対応や CI/CD を含め、設計から運用まで一貫して担当。</p>
            <div class="flex flex-wrap gap-1.5 mt-auto">
              {['Node.js', 'TypeScript', 'Express', 'MongoDB', 'Docker', 'AWS'].map(t => (
                <span class="bg-gray-100 text-gray-700 text-xs font-medium px-2.5 py-1 rounded-full">{t}</span>
              ))}
            </div>
          </div>
        </div>
        <div class="work-card bg-white text-gray-900 rounded-lg overflow-hidden hover:shadow-lg transition flex flex-col cursor-pointer" data-project="mobile-order">
          <img src="/images/server.png" alt="AWS・インフラ構築・運用" class="h-48 w-full object-cover">
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold mb-2">AWS・インフラ構築・運用</h3>
            <p class="text-sm text-gray-600 mb-4 flex-1">約 120 店舗展開中のモバイルオーダーシステムにおいて、Node.js メジャーバージョンアップ、本番 AWS 環境の構築・改善、CI/CD 整備、DocumentDB 移行など運用基盤を担当。</p>
            <div class="flex flex-wrap gap-1.5 mt-auto">
              {['AWS', 'Docker', 'Node.js', 'DocumentDB', 'Linux', 'CI/CD'].map(t => (
                <span class="bg-gray-100 text-gray-700 text-xs font-medium px-2.5 py-1 rounded-full">{t}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Project modal -->
      <div id="project-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" role="dialog" aria-modal="true">
        <div id="modal-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
        <div class="relative bg-white rounded-2xl w-full max-w-2xl max-h-[85vh] shadow-2xl flex flex-col">
          <button id="modal-close" aria-label="閉じる" class="absolute top-4 right-4 text-gray-400 hover:text-gray-700 transition p-1 z-10">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <div id="modal-body" class="p-8 overflow-y-auto flex-1"></div>
          <div class="border-t border-gray-200 p-4 flex justify-center shrink-0">
            <button class="modal-close-btn px-6 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition font-semibold">
              閉じる
            </button>
          </div>
        </div>
      </div>
      <div class="mt-8 text-center">
        <a href="/projects" class="text-gray-400 hover:text-gray-300 transition inline-flex items-center gap-2">
          すべてのプロジェクトを見る
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- About Me -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h2 class="text-5xl font-mono font-bold mb-12">About <span class="text-gray-400">Me</span></h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="flex justify-center">
          <img src="/images/icon.png" alt="プロフィール写真" class="w-64 h-64 rounded-full object-cover">
        </div>
        <div>
          <p class="text-gray-700 mb-4 leading-relaxed">バックエンドからAndroidアプリ・インフラまで幅広く担当しています。</p>
          <p class="text-gray-700 mb-4 leading-relaxed">0からの新規開発〜保守・改修まで経験しています。確実な技術と丁寧なコミュニケーションを大切にしながら、クライアント様のプロジェクトに向き合います。</p>
          <p class="text-gray-700 mb-6 leading-relaxed">長期的な運用を見据えた、品質の高いコード設計を心がけています。</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-full">Node.js</span>
            <span class="px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-full">Kotlin</span>
            <span class="px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-full">AWS</span>
            <span class="px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-full">Vue.js</span>
            <span class="px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-full">Docker</span>
            <span class="px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-full">Git</span>
          </div>
          <div class="mt-6">
            <a href="/about" class="inline-flex items-center gap-2 text-gray-500 hover:text-gray-600 transition">
              詳しく見る
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- サービスメニュー -->
  <section class="bg-gray-900 text-white py-20">
    <div class="max-w-4xl mx-auto px-6 w-full">
      <h2 class="text-5xl font-mono font-bold mb-2">Service <span class="text-gray-400">Menu</span></h2>
      <p class="text-gray-300 mb-12">提供しているサービスをご紹介します。</p>
      <div class="space-y-8">
        <div class="border-b border-gray-700 pb-8">
          <div class="flex gap-6">
            <span class="text-gray-400 text-3xl font-light">01</span>
            <div>
              <h3 class="text-2xl font-light mb-3">Android アプリ開発</h3>
              <p class="text-gray-400">Kotlin による Android アプリケーション開発。業務端末・券売機・POS などのハードウェア連携や、REST API との通信を含めたアプリを設計・開発します。</p>
            </div>
          </div>
        </div>
        <div class="border-b border-gray-700 pb-8">
          <div class="flex gap-6">
            <span class="text-gray-400 text-3xl font-light">02</span>
            <div>
              <h3 class="text-2xl font-light mb-3">バックエンド・API 開発</h3>
              <p class="text-gray-400">Node.js / Express を用いた Web API 開発。REST API の設計・実装からデータベース設計、CMS・POS 連携まで対応します。</p>
            </div>
          </div>
        </div>
        <div class="pb-8">
          <div class="flex gap-6">
            <span class="text-gray-400 text-3xl font-light">03</span>
            <div>
              <h3 class="text-2xl font-light mb-3">AWS・インフラ構築</h3>
              <p class="text-gray-400">AWS を利用した本番環境の構築・運用。EC2・DocumentDB・Docker・CI/CD・監視まで、安定したサービス運用を支えるインフラを構築します。</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- コンタクト -->
  <section class="py-20 bg-gray-100">
    <div class="max-w-2xl mx-auto px-6 w-full">
      <div class="bg-white rounded-lg p-12 text-center">
        <p class="text-gray-700 mb-4 leading-relaxed">案件のご相談やお気軽にお問い合わせください。</p>
        <p class="text-gray-700 mb-8 leading-relaxed">ホームページ制作から Web 開発まで、確実な技術でプロジェクトをサポートします。</p>
        <a href="/contact" class="inline-block bg-gray-900 hover:bg-gray-800 text-white font-semibold px-8 py-3 rounded transition">
          お問い合わせ
        </a>
      </div>
    </div>
  </section>


  <script>
    const projects: Record<string, {
      title: string;
      period: string;
      type: string;
      description: string;
      achievements: string[];
      tech: string[];
      responsibility?: string;
    }> = {
      android: {
        title: 'Android アプリ開発',
        period: '2025年10月 ～ 現在',
        type: '0ベース新規開発',
        responsibility: '設計 / 実装 / テスト',
        description: '飲食店向けセルフオーダー Android アプリをゼロから設計・開発。現金・キャッシュレス決済に対応し、釣銭機・決済端末・プリンターとのハードウェア連携を実装しました。\n\nCMS から取得したメニュー情報の表示、REST API 連携、オフライン時の表示継続、障害発生時のリカバリー処理まで対応し、約 10 店舗で運用されています。',
        achievements: [
          'Kotlin による Android アプリの設計・実装（MVVM 構成・Kotlin Coroutines）',
          '釣銭機・決済端末・プリンターとのハードウェア通信プロトコル実装',
          '現金・キャッシュレス決済フローの設計・実装',
          '現金決済時の障害リカバリーフロー設計（釣銭返却・強制完了・手動返金）',
          'バックエンド API との通信機能を実装',
          'CMS から取得したメニュー情報を SQLite へキャッシュし、オフライン時も表示を継続',
          'バーコードスキャンによるクーポン読み取り機能の実装',
          '日次締め処理など、店舗運用に必要な業務機能の実装',
        ],
        tech: ['Kotlin', 'Android', 'MVVM', 'Kotlin Coroutines', 'OkHttp', 'SQLite'],
      },
      cms: {
        title: 'セルフオーダー管理バックエンド',
        period: '2025年10月 ～ 現在',
        type: '0ベース新規開発',
        responsibility: '設計 / 実装 / テスト',
        description: 'Android 券売機向け Web CMS と POS 連携 REST API をゼロから設計・開発。\nマルチテナント対応、スペック駆動開発により、拡張性と保守性の高い API を実装。\n\n複数店舗・複数システムとの連携を実現し、スケーラブルなバックエンドアーキテクチャを構築しています。',
        achievements: [
          'Node.js・Express によるREST API の設計・実装（OpenAPI 仕様書作成）',
          'マルチテナント設計（Company→Branch→User 階層）',
          'MongoDB のスキーマ設計・クエリ最適化',
          'ページネーション・クエリ最適化によるパフォーマンス改善',
          'TypeScript による型安全な設計・実装',
          'エラーハンドリング、ロギング、ヘルスチェック API の実装',
          '仕様駆動開発による設計書・開発ガイドラインの整備',
          'Jest によるユニットテスト・API テストの実装',
        ],
        tech: ['Node.js', 'TypeScript', 'Express', 'MongoDB', 'Docker', 'Jest'],
      },
      'mobile-order': {
        title: 'AWS・インフラ構築・運用',
        period: '2025年10月 ～ 現在',
        type: '保守・機能改修',
        responsibility: '設計 / 実装 / 運用',
        description: '飲食店向けモバイルオーダーシステムの本番環境構築・運用を担当。約 120 店舗で稼働するシステムにおいて、Node.js のメジャーバージョンアップ、AWS インフラの構築・改善、本番・ステージング環境の分離構築を実施しました。\n\nDocker 環境の最適化や CI/CD の導入、監視基盤の整備を通じて、システムの安定性向上と運用効率化に取り組んでいます。',
        achievements: [
          'Node.js v12 → v24 へのメジャーバージョンアップ対応（互換性検証・依存ライブラリ更新）',
          'AWS インフラの設計・構築（EC2・ALB・Route 53・CloudWatch）',
          'Amazon DocumentDB へのデータベース移行（TLS/SSL 暗号化通信対応）',
          '本番・ステージング環境の分離構築',
          'Nginx によるリバースプロキシ設定・メンテナンスページ切替・SSL終端',
          'Docker コンテナイメージの最適化',
          'forever から systemd への移行によるサービス管理の標準化',
          'Bitbucket Pipelines を利用した CI/CD パイプラインの導入・構築',
        ],
        tech: ['AWS', 'EC2', 'Linux', 'Docker', 'Nginx', 'systemd', 'DocumentDB', 'CloudWatch', 'Bitbucket Pipelines'],
      },
    };

    const modal = document.getElementById('project-modal')!;
    const modalBody = document.getElementById('modal-body')!;
    const backdrop = document.getElementById('modal-backdrop')!;
    const closeBtn = document.getElementById('modal-close')!;

    function openModal(id: string) {
      const p = projects[id];
      if (!p) return;
      modalBody.innerHTML = `
        <div class="mb-1">
          <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full bg-gray-100 text-gray-600 mb-3">${p.type}</span>
          <h2 class="text-2xl font-bold text-gray-900 mb-1">${p.title}</h2>
          <p class="text-sm text-gray-400 mb-5">${p.period}</p>
        </div>
        ${p.responsibility ? `<p class="text-sm text-gray-600 font-semibold mb-4">担当範囲<br />${p.responsibility}</p>` : ''}
        <p class="text-gray-700 leading-relaxed mb-6 whitespace-pre-wrap">${p.description}</p>
        <div class="mb-6">
          <h3 class="text-sm font-semibold text-gray-900 mb-3">実績・対応内容</h3>
          <ul class="space-y-2">
            ${p.achievements.map(a => `
              <li class="flex gap-3 text-sm text-gray-700">
                <span class="text-gray-400 shrink-0 mt-0.5">✓</span>
                <span>${a}</span>
              </li>
            `).join('')}
          </ul>
        </div>
        <div class="flex flex-wrap gap-2">
          ${p.tech.map(t => `<span class="bg-gray-100 text-gray-700 text-xs font-medium px-3 py-1.5 rounded-full">${t}</span>`).join('')}
        </div>
      `;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }

    document.querySelectorAll<HTMLElement>('.work-card').forEach(card => {
      card.addEventListener('click', () => openModal(card.dataset.project!));
    });
    backdrop.addEventListener('click', closeModal);
    closeBtn.addEventListener('click', closeModal);
    document.querySelectorAll<HTMLElement>('.modal-close-btn').forEach(btn => {
      btn.addEventListener('click', closeModal);
    });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
  </script>
</BaseLayout>
