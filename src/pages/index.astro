---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="imurar - Portfolio">
  <!-- ヒーロー -->
  <section
    id="hero-section"
    class="relative overflow-hidden flex flex-col items-center justify-center"
    style="min-height: 72vh; background: linear-gradient(to bottom, #111827, #0a0a0a);"
  >
    <div id="hero-symbols" class="relative w-full"></div>
    <div class="text-center pb-16 font-mono">
      <p class="text-base tracking-widest text-gray-300 uppercase">Full Stack Engineer</p>
      <p class="text-sm text-gray-500 mt-1 tracking-wider">Node.js · Kotlin · AWS</p>
    </div>
  </section>

  <!-- 実績 / Selected Works -->
  <section class="bg-gray-900 text-white py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <div class="mb-12">
        <h2 class="text-5xl font-mono font-bold mb-2">Selected <span class="text-gray-400">Works</span></h2>
        <p class="text-gray-300">これまで携わった主なプロジェクトの一部をご紹介します。</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
        <div class="work-card bg-white text-gray-900 rounded-lg overflow-hidden hover:shadow-lg transition flex flex-col cursor-pointer" data-project="android">
          <img src="/images/android.jpg" alt="Android アプリ開発" class="h-48 w-full object-cover">
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold mb-2">Android アプリ開発</h3>
            <p class="text-sm text-gray-600 mb-4 flex-1">飲食店向けセルフオーダー型 Android 券売機を 0 から設計・開発。釣銭機・決済端末・プリンターとのハードウェア連携、Node.js CMS バックエンドまでフルスタックで担当。</p>
            <div class="flex flex-wrap gap-1.5 mt-auto">
              {['Kotlin', 'Android', 'Kotlin Coroutines', 'SQLite'].map(t => (
                <span class="bg-gray-100 text-gray-700 text-xs font-medium px-2.5 py-1 rounded-full">{t}</span>
              ))}
            </div>
          </div>
        </div>
        <div class="work-card bg-white text-gray-900 rounded-lg overflow-hidden hover:shadow-lg transition flex flex-col cursor-pointer" data-project="cms">
          <img src="/images/backend.jpg" alt="セルフオーダー管理バックエンド" class="h-48 w-full object-cover">
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold mb-2">セルフオーダー管理バックエンド</h3>
            <p class="text-sm text-gray-600 mb-4 flex-1">Android 券売機向け Web CMS と POS 連携 REST API を 0 から設計・開発。マルチテナント設計・スペック駆動開発・CI/CD 構築まで一貫して担当。</p>
            <div class="flex flex-wrap gap-1.5 mt-auto">
              {['Node.js', 'TypeScript', 'Express', 'MongoDB', 'AWS', 'Docker'].map(t => (
                <span class="bg-gray-100 text-gray-700 text-xs font-medium px-2.5 py-1 rounded-full">{t}</span>
              ))}
            </div>
          </div>
        </div>
        <div class="work-card bg-white text-gray-900 rounded-lg overflow-hidden hover:shadow-lg transition flex flex-col cursor-pointer" data-project="mobile-order">
          <img src="/images/mobile-order.jpg" alt="モバイルオーダーシステム保守・改修" class="h-48 w-full object-cover">
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-bold mb-2">モバイルオーダー保守・改修</h3>
            <p class="text-sm text-gray-600 mb-4 flex-1">約 120 店舗展開中の QR コード型モバイルオーダーシステムを担当。Node.js v12 → v24 のメジャーバージョンアップと AWS インフラ整備を主導。</p>
            <div class="flex flex-wrap gap-1.5 mt-auto">
              {['Node.js', 'JavaScript', 'Express', 'Amazon DocumentDB', 'AWS', 'Docker'].map(t => (
                <span class="bg-gray-100 text-gray-700 text-xs font-medium px-2.5 py-1 rounded-full">{t}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Project modal -->
      <div id="project-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" role="dialog" aria-modal="true">
        <div id="modal-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
        <div class="relative bg-white rounded-2xl w-full max-w-2xl max-h-[85vh] overflow-y-auto shadow-2xl">
          <button id="modal-close" aria-label="閉じる" class="absolute top-4 right-4 text-gray-400 hover:text-gray-700 transition p-1">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
          <div id="modal-body" class="p-8"></div>
        </div>
      </div>
      <div class="mt-8 text-center">
        <a href="/projects" class="text-gray-400 hover:text-gray-300 transition inline-flex items-center gap-2">
          すべてのプロジェクトを見る
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- About Me -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h2 class="text-5xl font-mono font-bold mb-12">About <span class="text-gray-400">Me</span></h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="flex justify-center">
          <img src="/images/icon.png" alt="プロフィール写真" class="w-64 h-64 rounded-full object-cover">
        </div>
        <div>
          <p class="text-gray-700 mb-4 leading-relaxed">バックエンドからAndroidアプリ・インフラまで幅広く担当しています。</p>
          <p class="text-gray-700 mb-4 leading-relaxed">0からの新規開発〜保守・改修まで経験しています。確実な技術と丁寧なコミュニケーションを大切にしながら、クライアント様のプロジェクトに向き合います。</p>
          <p class="text-gray-700 mb-6 leading-relaxed">長期的な運用を見据えた、品質の高いコード設計を心がけています。</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-full">Node.js</span>
            <span class="px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-full">Kotlin</span>
            <span class="px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-full">AWS</span>
            <span class="px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-full">Vue.js</span>
            <span class="px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-full">Docker</span>
            <span class="px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-full">Git</span>
          </div>
          <div class="mt-6">
            <a href="/about" class="inline-flex items-center gap-2 text-gray-500 hover:text-gray-600 transition">
              詳しく見る
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- サービスメニュー -->
  <section class="bg-gray-900 text-white py-20">
    <div class="max-w-4xl mx-auto px-6 w-full">
      <h2 class="text-5xl font-mono font-bold mb-2">Service <span class="text-gray-400">Menu</span></h2>
      <p class="text-gray-300 mb-12">提供しているサービスをご紹介します。</p>
      <div class="space-y-8">
        <div class="border-b border-gray-700 pb-8">
          <div class="flex gap-6">
            <span class="text-gray-400 text-3xl font-light">01</span>
            <div>
              <h3 class="text-2xl font-light mb-3">フロントエンド開発</h3>
              <p class="text-gray-400">HTML / CSS / JavaScript / Vue.js を用いたフロントエンド開発。デザインデータから実装まで対応します。</p>
            </div>
          </div>
        </div>
        <div class="border-b border-gray-700 pb-8">
          <div class="flex gap-6">
            <span class="text-gray-400 text-3xl font-light">02</span>
            <div>
              <h3 class="text-2xl font-light mb-3">バックエンド開発</h3>
              <p class="text-gray-400">Node.js / PHP / Python など、幅広い言語によるバックエンド開発。AWS インフラにも対応。</p>
            </div>
          </div>
        </div>
        <div class="pb-8">
          <div class="flex gap-6">
            <span class="text-gray-400 text-3xl font-light">03</span>
            <div>
              <h3 class="text-2xl font-light mb-3">モバイル開発</h3>
              <p class="text-gray-400">Kotlin / Android による、スマートフォンアプリケーション開発。バックエンド と の統合対応も可能。</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- コンタクト -->
  <section class="py-20 bg-gray-100">
    <div class="max-w-2xl mx-auto px-6 w-full">
      <div class="bg-white rounded-lg p-12 text-center">
        <p class="text-gray-700 mb-4 leading-relaxed">案件のご相談やお気軽にお問い合わせください。</p>
        <p class="text-gray-700 mb-8 leading-relaxed">ホームページ制作から Web 開発まで、確実な技術でプロジェクトをサポートします。</p>
        <a href="/contact" class="inline-block bg-gray-900 hover:bg-gray-800 text-white font-semibold px-8 py-3 rounded transition">
          お問い合わせ
        </a>
      </div>
    </div>
  </section>

  <style>
    @keyframes symSpin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
  </style>

  <script>
    import { buildHero, onResize } from '../scripts/hero';
    buildHero();
    window.addEventListener('resize', onResize);
  </script>

  <script>
    const projects: Record<string, {
      title: string;
      period: string;
      type: string;
      description: string;
      achievements: string[];
      tech: string[];
    }> = {
      android: {
        title: 'Android アプリ開発',
        period: '2025年10月 〜 現在',
        type: '0ベース新規開発',
        description: '飲食店舗向けセルフオーダー型 Android アプリを 0 から設計・開発。現金・キャッシュレスの両決済に対応し、各種ハードウェアとの通信プロトコルを実装。約 10 店舗に展開中。',
        achievements: [
          'Kotlin による Android アプリ設計・実装（MVVM 構成・Kotlin Coroutines）',
          '釣銭機・決済端末・プリンターとのハードウェア通信プロトコル実装',
          '現金決済の障害リカバリーフロー設計（釣銭返却・強制完了・手動返金）',
          'CMS から取得したメニューレイアウトを SQLite にキャッシュし、オフライン時も表示継続',
          'バーコードスキャンによるクーポン読み取り・日次締め処理実装',
        ],
        tech: ['Kotlin', 'Android', 'Kotlin Coroutines', 'SQLite'],
      },
      cms: {
        title: 'セルフオーダー管理バックエンド',
        period: '2025年10月 〜 現在',
        type: '0ベース新規開発',
        description: 'Android 券売機向け Web CMS と POS 連携 REST API を設計・開発。マルチテナント設計・スペック駆動開発・CI/CD 構築まで一貫して担当。',
        achievements: [
          'Node.js / Express 5 による Web CMS・POS 連携 REST API の設計・実装',
          'マルチテナント設計（Company → Branch → User 階層、全クエリに branch 条件を強制）',
          'N+1 クエリ回避・ヘルスチェック API など API 設計工夫',
          'スペック駆動開発（PRD・機能設計書・アーキテクチャ設計書・開発ガイドラインを整備）',
          'Bitbucket Pipelines による staging / production への CI/CD 自動デプロイ',
        ],
        tech: ['Node.js', 'TypeScript', 'Express', 'MongoDB', 'AWS', 'Docker'],
      },
      'mobile-order': {
        title: 'モバイルオーダーシステム保守・改修',
        period: '2025年10月 〜 現在',
        type: '保守・機能改修',
        description: '飲食店向け QR コードモバイルオーダーシステムの保守・改修。約 120 店舗展開中のシステムで、Node.js v12 → v24 への複数メジャーバージョンを跨ぐアップグレードとインフラ整備を担当。',
        achievements: [
          'Node.js v12 → v24 メジャーバージョンアップ（複数バージョンを跨ぐ互換性対応を主導）',
          'Socket.IO v4 / fast-xml-parser v4 / connect-mongo v6 / Mongoose 8 移行対応',
          'AWS SDK v2 → v3（@aws-sdk/client-s3）移行',
          'Amazon DocumentDB への MongoDB 移行（TLS/SSL 対応）',
          '本番・STG が同居していた EC2 を分離し、本番・ステージング環境をそれぞれ独立して構築',
        ],
        tech: ['Node.js', 'JavaScript', 'Express', 'Amazon DocumentDB', 'AWS', 'Docker'],
      },
    };

    const modal = document.getElementById('project-modal')!;
    const modalBody = document.getElementById('modal-body')!;
    const backdrop = document.getElementById('modal-backdrop')!;
    const closeBtn = document.getElementById('modal-close')!;

    function openModal(id: string) {
      const p = projects[id];
      if (!p) return;
      modalBody.innerHTML = `
        <div class="mb-1">
          <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full bg-gray-100 text-gray-600 mb-3">${p.type}</span>
          <h2 class="text-2xl font-bold text-gray-900 mb-1">${p.title}</h2>
          <p class="text-sm text-gray-400 mb-5">${p.period}</p>
        </div>
        <p class="text-gray-700 leading-relaxed mb-6">${p.description}</p>
        <div class="mb-6">
          <h3 class="text-sm font-semibold text-gray-900 mb-3">実績・対応内容</h3>
          <ul class="space-y-2">
            ${p.achievements.map(a => `
              <li class="flex gap-3 text-sm text-gray-700">
                <span class="text-gray-400 shrink-0 mt-0.5">✓</span>
                <span>${a}</span>
              </li>
            `).join('')}
          </ul>
        </div>
        <div class="flex flex-wrap gap-2">
          ${p.tech.map(t => `<span class="bg-gray-100 text-gray-700 text-xs font-medium px-3 py-1.5 rounded-full">${t}</span>`).join('')}
        </div>
      `;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }

    document.querySelectorAll<HTMLElement>('.work-card').forEach(card => {
      card.addEventListener('click', () => openModal(card.dataset.project!));
    });
    backdrop.addEventListener('click', closeModal);
    closeBtn.addEventListener('click', closeModal);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
  </script>
</BaseLayout>
