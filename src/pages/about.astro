---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="プロフィール - imogx">
  <!-- ヒーロー -->
  <section class="bg-gray-900 text-white py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h1 class="text-5xl font-mono font-bold mb-2">Profile</h1>
      <p class="text-gray-300">バックエンドエンジニア / クラウドエンジニア<br />確実な技術とコミュニケーションで、クライアントをサポートします</p>
    </div>
  </section>

  <!-- Profile -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="flex justify-center">
          <img src="/images/icon.png" alt="プロフィール写真" class="w-56 h-56 rounded-full object-cover">
        </div>
        <div>
          <h2 class="text-4xl font-bold mb-6 leading-tight">
            Node.js・AWS を軸に、<br />
            バックエンドからクラウドまで<br />
            一貫して開発しています。
          </h2>
          <p class="text-gray-700 mb-4 leading-relaxed">要件定義から設計・実装・運用まで一貫して担当。Node.js・AWS を中心としたバックエンド・クラウド開発に加え、Kotlin による Android アプリ開発にも携わっています。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Career Highlights -->
  <section class="bg-gray-100 py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-md transition text-center">
          <p class="text-5xl font-bold text-gray-900 mb-2">4+</p>
          <p class="text-gray-600">実務経験</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-md transition text-center">
          <p class="text-5xl font-bold text-gray-900 mb-2">120</p>
          <p class="text-gray-600">店舗導入実績</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-md transition text-center">
          <p class="text-5xl font-bold text-gray-900 mb-2">2</p>
          <p class="text-gray-600">ゼロイチ開発</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-md transition text-center">
          <p class="text-5xl font-bold text-gray-900 mb-2">15+</p>
          <p class="text-gray-600">利用技術</p>
        </div>
      </div>
    </div>
  </section>

  <!-- スキル -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h2 class="text-4xl font-mono font-bold mb-12">スキル</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-lg transition">
          <h3 class="text-xl font-bold mb-4">Languages</h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">TypeScript</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">JavaScript</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">PHP</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">Kotlin</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">SQL</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">HTML/CSS</span>
          </div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-lg transition">
          <h3 class="text-xl font-bold mb-4">Backend</h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">Node.js</span>
            <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">Express</span>
            <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">Laravel</span>
            <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">CakePHP</span>
            <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">Socket.IO</span>
          </div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-lg transition">
          <h3 class="text-xl font-bold mb-4">Mobile</h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-indigo-100 text-indigo-700 text-sm rounded-full">Android</span>
            <span class="px-3 py-1 bg-indigo-100 text-indigo-700 text-sm rounded-full">MVVM</span>
            <span class="px-3 py-1 bg-indigo-100 text-indigo-700 text-sm rounded-full">Kotlin Coroutines</span>
          </div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-lg transition">
          <h3 class="text-xl font-bold mb-4">Database</h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-amber-100 text-amber-700 text-sm rounded-full">MySQL</span>
            <span class="px-3 py-1 bg-amber-100 text-amber-700 text-sm rounded-full">MongoDB</span>
            <span class="px-3 py-1 bg-amber-100 text-amber-700 text-sm rounded-full">Amazon DocumentDB</span>
            <span class="px-3 py-1 bg-amber-100 text-amber-700 text-sm rounded-full">SQLite</span>
            <span class="px-3 py-1 bg-amber-100 text-amber-700 text-sm rounded-full">SQL Server</span>
            <span class="px-3 py-1 bg-amber-100 text-amber-700 text-sm rounded-full">Oracle</span>
          </div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-lg transition">
          <h3 class="text-xl font-bold mb-4">Cloud & DevOps</h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">AWS</span>
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">Linux</span>
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">Docker</span>
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">Nginx</span>
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">systemd</span>
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">CloudWatch</span>
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">Bitbucket Pipelines</span>
          </div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-lg transition">
          <h3 class="text-xl font-bold mb-4">Development Tools</h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-rose-100 text-rose-700 text-sm rounded-full">Git</span>
            <span class="px-3 py-1 bg-rose-100 text-rose-700 text-sm rounded-full">GitHub</span>
            <span class="px-3 py-1 bg-rose-100 text-rose-700 text-sm rounded-full">Bitbucket</span>
            <span class="px-3 py-1 bg-rose-100 text-rose-700 text-sm rounded-full">VS Code</span>
            <span class="px-3 py-1 bg-rose-100 text-rose-700 text-sm rounded-full">Android Studio</span>
            <span class="px-3 py-1 bg-rose-100 text-rose-700 text-sm rounded-full">Postman</span>
            <span class="px-3 py-1 bg-rose-100 text-rose-700 text-sm rounded-full">Claude Code</span>
            <span class="px-3 py-1 bg-rose-100 text-rose-700 text-sm rounded-full">Codex</span>
            <span class="px-3 py-1 bg-rose-100 text-rose-700 text-sm rounded-full">ChatGPT</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- リンク -->
  <section class="bg-gray-900 text-white py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h2 class="text-4xl font-mono font-bold mb-12">Links</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="https://github.com/imogx" target="_blank" rel="noopener noreferrer"
          class="bg-gray-800 hover:bg-gray-900 border border-gray-700 rounded-xl p-8 transition flex flex-col items-center text-center">
          <div class="h-24 flex items-center justify-center mb-4">
            <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.868-.013-1.703-2.782.603-3.369-1.343-3.369-1.343-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.545 2.914 1.209.092-.937.35-1.546.636-1.903-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0110 4.817c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C17.138 18.192 20 14.435 20 10.017 20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="text-xl font-bold">GitHub</h3>
          <p class="text-gray-300 text-sm mt-2">コードをチェック</p>
        </a>
        <a href="https://github.com/imogx/imogx.github.io" target="_blank" rel="noopener noreferrer"
          class="bg-gray-800 hover:bg-gray-900 border border-gray-700 rounded-xl p-8 transition flex flex-col items-center text-center">
          <div class="h-24 flex items-center justify-center mb-4">
            <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.868-.013-1.703-2.782.603-3.369-1.343-3.369-1.343-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.545 2.914 1.209.092-.937.35-1.546.636-1.903-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0110 4.817c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C17.138 18.192 20 14.435 20 10.017 20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="text-xl font-bold">ソースコード</h3>
          <p class="text-gray-300 text-sm mt-2">このサイト</p>
        </a>
        <a href="https://imogx.github.io/necogokochi/" target="_blank" rel="noopener noreferrer"
          class="bg-gray-800 hover:bg-gray-900 border border-gray-700 rounded-xl p-8 transition flex flex-col items-center text-center">
          <div class="h-24 flex items-center justify-center mb-4">
            <svg class="w-24 h-24" viewBox="0 0 300 300" fill="white" stroke="white" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M194.31,140.55c0.9-11.6-1.18-19.51-5.25-34.29c-0.53-1.91-2.96-2.49-4.28-1.01c-9.01,10.08-17.63,18.5-22.59,31.22H137.8c-4.96-12.72-13.58-21.14-22.59-31.22c-1.32-1.48-3.75-0.9-4.28,1.01c-4.07,14.78-6.15,22.68-5.25,34.29c-2.09,1.97-10.11,19.8-9.96,29.8c0.15,10.09,3.39,18.91,12.9,21.94c13.79,4.39,68.95,4.39,82.74,0c9.51-3.03,12.75-11.85,12.9-21.94C204.42,160.35,196.41,142.52,194.31,140.55z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold">ねこごこち</h3>
          <p class="text-gray-300 text-sm mt-2">猫の気持ち予習サイト</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
