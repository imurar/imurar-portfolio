---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="プロフィール - imurar">
  <!-- ヒーロー -->
  <section class="bg-gray-900 text-white py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h1 class="text-5xl font-mono font-bold mb-2">Profile</h1>
      <p class="text-gray-300">フルスタックエンジニア<br />確実な技術とコミュニケーションで、クライアントをサポートします</p>
    </div>
  </section>

  <!-- プロフィール -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="flex justify-center">
          <img src="/images/profile.jpg" alt="プロフィール写真" class="w-64 h-64 rounded-full object-cover">
        </div>
        <div>
          <p class="text-gray-700 mb-4 leading-relaxed">確実な技術と丁寧なコミュニケーションで、クライアント様のプロジェクトをサポートしています。</p>
          <p class="text-gray-700 mb-4 leading-relaxed">HTML / CSS / JavaScript を用いたホームページ制作から、Node.js によるバックエンド開発、Kotlin Android アプリ開発、AWS インフラ構築まで、フルスタックで対応可能です。</p>
          <p class="text-gray-700 mb-6 leading-relaxed">品質の高いコードで、長期的な運用をサポートします。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 基本情報 -->
  <section class="bg-gray-100 py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h2 class="text-4xl font-mono font-bold mb-12">基本情報</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
          <p class="text-gray-500 text-sm mb-2">名前</p>
          <p class="text-2xl font-bold">井村りゅうき</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
          <p class="text-gray-500 text-sm mb-2">年齢</p>
          <p class="text-2xl font-bold">26歳</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
          <p class="text-gray-500 text-sm mb-2">居住地</p>
          <p class="text-2xl font-bold">神奈川県横浜市</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
          <p class="text-gray-500 text-sm mb-2">職業</p>
          <p class="text-2xl font-bold">Web・Androidエンジニア</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
          <p class="text-gray-500 text-sm mb-2">MBTI</p>
          <p class="text-2xl font-bold">ENFJ-A</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md transition">
          <p class="text-gray-500 text-sm mb-2">趣味</p>
          <p class="text-2xl font-bold">読書 / スポーツ観戦 / 食べ歩き</p>
        </div>
      </div>
    </div>
  </section>

  <!-- スキル -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h2 class="text-4xl font-mono font-bold mb-12">スキル</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-lg transition">
          <h3 class="text-xl font-bold mb-4">フロントエンド</h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">HTML/CSS</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">JavaScript</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">Vue.js</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">Tailwind</span>
          </div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-lg transition">
          <h3 class="text-xl font-bold mb-4">バックエンド</h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">Node.js</span>
            <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">Express</span>
            <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">MongoDB</span>
            <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">PHP</span>
          </div>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-8 hover:shadow-lg transition">
          <h3 class="text-xl font-bold mb-4">モバイル・インフラ</h3>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">Kotlin</span>
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">AWS</span>
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">Docker</span>
            <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">Git</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- リンク -->
  <section class="bg-gray-900 text-white py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h2 class="text-4xl font-mono font-bold mb-12">Links</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="https://github.com/imurar" target="_blank" rel="noopener noreferrer"
          class="bg-gray-800 hover:bg-gray-900 border border-gray-700 rounded-xl p-8 transition flex flex-col items-center text-center">
          <svg class="w-12 h-12 mb-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.868-.013-1.703-2.782.603-3.369-1.343-3.369-1.343-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.545 2.914 1.209.092-.937.35-1.546.636-1.903-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0110 4.817c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C17.138 18.192 20 14.435 20 10.017 20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
          </svg>
          <h3 class="text-xl font-bold">GitHub</h3>
          <p class="text-gray-300 text-sm mt-2">コードをチェック</p>
        </a>
        <a href="https://qiita.com/imurar" target="_blank" rel="noopener noreferrer"
          class="bg-gray-800 hover:bg-gray-900 border border-gray-700 rounded-xl p-8 transition flex flex-col items-center text-center">
          <svg class="w-12 h-12 mb-4" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="12" r="11" fill="currentColor"/>
            <path d="M8 10C8 8.9 7.1 8 6 8C4.9 8 4 8.9 4 10C4 11.1 4.9 12 6 12C7.1 12 8 11.1 8 10Z" fill="#1a1a1a"/>
            <path d="M16 10C16 8.9 15.1 8 14 8C12.9 8 12 8.9 12 10C12 11.1 12.9 12 14 12C15.1 12 16 11.1 16 10Z" fill="#1a1a1a"/>
            <path d="M10 16C10 15.4 10.4 15 11 15H13C13.6 15 14 15.4 14 16C14 16.6 13.6 17 13 17H11C10.4 17 10 16.6 10 16Z" fill="#1a1a1a"/>
          </svg>
          <h3 class="text-xl font-bold">Qiita</h3>
          <p class="text-gray-300 text-sm mt-2">技術記事</p>
        </a>
        <a href="https://github.com/imurar/imurar.github.io" target="_blank" rel="noopener noreferrer"
          class="bg-gray-800 hover:bg-gray-900 border border-gray-700 rounded-xl p-8 transition flex flex-col items-center text-center">
          <svg class="w-12 h-12 mb-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.868-.013-1.703-2.782.603-3.369-1.343-3.369-1.343-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.545 2.914 1.209.092-.937.35-1.546.636-1.903-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0110 4.817c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C17.138 18.192 20 14.435 20 10.017 20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
          </svg>
          <h3 class="text-xl font-bold">ソースコード</h3>
          <p class="text-gray-300 text-sm mt-2">このサイト</p>
        </a>
        <a href="https://imurar.github.io/necogokochi/" target="_blank" rel="noopener noreferrer"
          class="bg-gray-800 hover:bg-gray-900 border border-gray-700 rounded-xl p-8 transition flex flex-col items-center text-center">
          <svg class="w-12 h-12 mb-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 22C7.5 22 3 18 3 13C3 10 4 8 6 6.5L3.5 2L8 6C9 5.2 10.4 4.8 12 4.8C13.6 4.8 15 5.2 16 6L20.5 2L18 6.5C20 8 21 10 21 13C21 18 16.5 22 12 22ZM9 11.7A1.3 1.3 0 1 0 9 14.3A1.3 1.3 0 1 0 9 11.7ZM15 11.7A1.3 1.3 0 1 0 15 14.3A1.3 1.3 0 1 0 15 11.7Z" />
          </svg>
          <h3 class="text-xl font-bold">ねこごこち</h3>
          <p class="text-gray-300 text-sm mt-2">猫の気持ち予習サイト</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
