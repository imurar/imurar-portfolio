---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const demos = [
  {
    href: `${base}/demo/ui/`,
    title: 'UI コンポーネント',
    description: 'ボタン・バッジ・カード・アラート・フォームパーツのサンプル集',
    icon: '🎨',
  },
  {
    href: `${base}/demo/animation/`,
    title: 'CSS アニメーション',
    description: 'フェードイン・スライド・ホバーエフェクト・ローディングのデモ',
    icon: '✨',
  },
  {
    href: `${base}/demo/counter/`,
    title: '文字数カウンター',
    description: 'リアルタイムで文字数・行数・残り文字数を表示するツール',
    icon: '📝',
  },
  {
    href: `${base}/demo/todo/`,
    title: 'ToDoリスト',
    description: 'タスクの追加・完了・削除・フィルタリングができるアプリ',
    icon: '✅',
  },
];
---

<Layout title="Demo | imurar">
  <section>
    <h1 class="text-3xl font-bold mb-2">Demo</h1>
    <p class="text-gray-600 mb-12">HTML / CSS / JavaScript で実装したコンポーネント・ツールのサンプルです。</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {demos.map((demo) => (
        <a href={demo.href} class="border border-gray-200 rounded-xl p-6 hover:shadow-md hover:border-gray-300 transition group">
          <div class="text-3xl mb-3">{demo.icon}</div>
          <h2 class="text-lg font-bold mb-1 group-hover:text-gray-600 transition">{demo.title}</h2>
          <p class="text-sm text-gray-500">{demo.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
