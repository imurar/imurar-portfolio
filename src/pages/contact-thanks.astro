---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="送信完了 - imogx">
  <div class="max-w-4xl mx-auto px-6 py-12 w-full">
    <section class="max-w-xl mx-auto text-center py-16">
      <div class="text-5xl mb-6">✉️</div>
      <h1 class="text-2xl font-bold mb-4">送信完了しました</h1>
      <p class="text-gray-600 mb-8">
        お問い合わせありがとうございます。<br />
        内容を確認の上、ご連絡いたします。
      </p>
      <a href="/"
        class="inline-block bg-gray-900 text-white font-semibold py-3 px-8 rounded-lg hover:bg-gray-700 transition">
        トップへ戻る
      </a>
    </section>
  </div>
</BaseLayout>
