---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="お問い合わせ - imurar">
  <!-- ヒーロー -->
  <section class="bg-gray-900 text-white py-20">
    <div class="max-w-6xl mx-auto px-6 w-full">
      <h1 class="text-5xl font-mono font-bold mb-2">Contact</h1>
      <p class="text-gray-300">お気軽にお問い合わせください</p>
    </div>
  </section>

  <!-- コンタクトフォーム -->
  <section class="py-20">
    <div class="max-w-2xl mx-auto px-6 w-full">
      <div class="bg-white border border-gray-200 rounded-xl p-12">
        <div class="mb-8">
          <p class="text-gray-700 mb-3 leading-relaxed">制作のご依頼・ご相談はお気軽にどうぞ。</p>
          <p class="text-gray-600 text-sm">2営業日以内にご返信いたします。</p>
        </div>

        <form
          action="https://formsubmit.co/970f5070ee9d32a17c76a53ed47d36dd"
          method="POST"
          class="flex flex-col gap-6"
        >
          <input type="hidden" name="_subject" value="ポートフォリオからのお問い合わせ" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://imurar.github.io/contact-thanks" />

          <div>
            <label for="name" class="block text-sm font-semibold text-gray-900 mb-2">お名前 <span class="text-red-500">*</span></label>
            <input type="text" id="name" name="name" required placeholder="山田 太郎"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gray-500 transition" />
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-gray-900 mb-2">メールアドレス <span class="text-red-500">*</span></label>
            <input type="email" id="email" name="email" required placeholder="example@email.com"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gray-500 transition" />
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-gray-900 mb-2">メッセージ <span class="text-red-500">*</span></label>
            <textarea id="message" name="message" required rows="6" placeholder="ご依頼内容・ご相談内容をご記入ください"
              class="w-full border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-gray-500 transition resize-none"></textarea>
          </div>

          <button type="submit"
            class="bg-gray-900 hover:bg-gray-800 text-white font-semibold py-3 px-8 rounded-lg transition w-full">
            送信する
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
