---
export interface Props {
  title?: string;
}

const { title = 'imurar - Portfolio' } = Astro.props;
const currentPath = Astro.url.pathname;
const hideHeaderFooter = currentPath.includes('/demo/safe-area');
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style is:global>
      @import "tailwindcss";
    </style>
  </head>
  <body class="bg-white text-gray-900">
    {!hideHeaderFooter && (
      <header class="bg-gray-900 text-white shadow sticky top-0 z-50">
        <nav class="max-w-4xl mx-auto px-6 py-4 flex justify-between items-center">
          <a href="/" class="text-xl font-bold hover:text-gray-300 transition font-mono tracking-tight whitespace-nowrap">
            &lt; imurar /&gt;
          </a>

          <!-- PC メニュー -->
          <ul class="hidden md:flex gap-8 text-base">
            <li><a href="/" class="hover:text-gray-300 transition">Home</a></li>
            <li><a href="/about" class="hover:text-gray-300 transition">Profile</a></li>
            <li><a href="/projects" class="hover:text-gray-300 transition">Projects</a></li>
            <li><a href="/contact" class="hover:text-gray-300 transition">Contact</a></li>
          </ul>

          <!-- ハンバーガーボタン（スマホ） -->
          <button id="hamburger-btn" class="md:hidden p-2 hover:text-gray-300 transition">
            <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </nav>

        <!-- スマホ メニュー -->
        <div id="mobile-menu" class="md:hidden bg-gray-800 border-t border-gray-700 hidden">
          <ul class="flex flex-col px-6 py-4 space-y-3 text-sm">
            <li><a href="/" class="block hover:text-gray-300 transition">Home</a></li>
            <li><a href="/about" class="block hover:text-gray-300 transition">Profile</a></li>
            <li><a href="/projects" class="block hover:text-gray-300 transition">Projects</a></li>
            <li><a href="/contact" class="block hover:text-gray-300 transition">Contact</a></li>
          </ul>
        </div>
      </header>
    )}

    <!-- メインコンテンツ -->
    <main class="flex flex-col min-h-screen">
      <slot />
    </main>

    {!hideHeaderFooter && (
      <footer class="bg-gray-900 text-white text-center py-6 mt-12">
        <p>&copy; 2026 imurar. All rights reserved.</p>
      </footer>
    )}

    <script>
      // ハンバーガーメニューの生JS実装
      const btn = document.getElementById('hamburger-btn');
      const menu = document.getElementById('mobile-menu');
      const icon = document.getElementById('hamburger-icon');

      if (btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('hidden');

          // アイコンを切り替え（メニュー開閉時）
          const isOpen = !menu.classList.contains('hidden');
          const hamburgerPath = 'M4 6h16M4 12h16M4 18h16';
          const closePath = 'M6 18L18 6M6 6l12 12';

          if (icon && icon.querySelector('path')) {
            const path = icon.querySelector('path');
            if (path) {
              path.setAttribute('d', isOpen ? closePath : hamburgerPath);
            }
          }
        });

        // メニュー内のリンククリック時にメニューを閉じる
        const menuLinks = menu.querySelectorAll('a');
        menuLinks.forEach(link => {
          link.addEventListener('click', () => {
            menu.classList.add('hidden');
            if (icon && icon.querySelector('path')) {
              const path = icon.querySelector('path');
              if (path) {
                path.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
              }
            }
          });
        });
      }
    </script>
  </body>
</html>
